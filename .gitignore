# ===================================================================
# Twilight Blog - .gitignore
# ===================================================================

# ===================== 编辑器配置 =====================
**/.vscode/
**/.idea/
*.swp
*.swo
*~

# ===================== 依赖文件 =====================
node_modules/
.pnpm-store/

# ===================== 生成的文件 =====================
.astro/
.vercel/
.netlify/
.output/

# ===================== 构建输出 =====================
dist/

# ===================== 日志文件 =====================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===================== 私有配置 =====================
.env
.env.local
.env.*.local

# ===================== 系统文件 =====================
.DS_Store
Thumbs.db
Desktop.ini

# ===================== 备份文件 =====================
backups/
*.bak
*.backup

# ===================== 缓存 =====================
.cache/
.parcel-cache/
.turbo/

# ===================== 测试覆盖率 =====================
coverage/
.nyc_output/

# ===================== 临时文件 =====================
*.tmp
*.temp
.tmp/
.temp/

# ===================== Gemini AI 工作目录 =====================
.gemini/
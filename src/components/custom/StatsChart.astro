---
/**
 * 动态统计图表组件
 * 展示博客统计数据，带动画效果
 * 
 * 使用方法:
 * <StatsChart stats={[{label, value, icon, color}]} animated />
 */

interface StatItem {
  label: string;
  value: number;
  icon?: string;
  color?: 'blue' | 'green' | 'purple' | 'orange' | 'pink' | 'cyan';
  suffix?: string;
}

interface Props {
  stats: StatItem[];
  title?: string;
  animated?: boolean;
  layout?: 'grid' | 'row';
  class?: string;
}

const { 
  stats, 
  title,
  animated = true,
  layout = 'grid',
  class: className 
} = Astro.props;

const colorClasses = {
  blue: { bg: 'bg-blue-500/10', text: 'text-blue-500', border: 'border-blue-500/30', ring: 'ring-blue-500/20' },
  green: { bg: 'bg-green-500/10', text: 'text-green-500', border: 'border-green-500/30', ring: 'ring-green-500/20' },
  purple: { bg: 'bg-purple-500/10', text: 'text-purple-500', border: 'border-purple-500/30', ring: 'ring-purple-500/20' },
  orange: { bg: 'bg-orange-500/10', text: 'text-orange-500', border: 'border-orange-500/30', ring: 'ring-orange-500/20' },
  pink: { bg: 'bg-pink-500/10', text: 'text-pink-500', border: 'border-pink-500/30', ring: 'ring-pink-500/20' },
  cyan: { bg: 'bg-cyan-500/10', text: 'text-cyan-500', border: 'border-cyan-500/30', ring: 'ring-cyan-500/20' },
};

const defaultIcons = ['📊', '📝', '🏷️', '📁', '👁️', '💬'];
---

<div 
  class:list={['stats-chart-container', className]}
  data-animated={animated}
>
  {title && (
    <h3 class="text-xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-2">
      <span class="w-1 h-6 bg-primary-500 rounded-full"></span>
      {title}
    </h3>
  )}
  
  <div class:list={[
    layout === 'grid' ? 'grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4' : 'flex flex-wrap gap-4'
  ]}>
    {stats.map((stat, index) => {
      const color = stat.color || (['blue', 'green', 'purple', 'orange', 'pink', 'cyan'][index % 6] as keyof typeof colorClasses);
      const colors = colorClasses[color];
      const icon = stat.icon || defaultIcons[index % defaultIcons.length];
      
      return (
        <div 
          class:list={[
            'stat-card group relative overflow-hidden rounded-2xl p-5 border transition-all duration-300 hover:scale-105 hover:shadow-lg',
            colors.bg,
            colors.border,
            `hover:${colors.ring} hover:ring-4`
          ]}
          data-value={stat.value}
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- 背景装饰 -->
          <div class={`absolute -right-4 -top-4 w-20 h-20 rounded-full ${colors.bg} opacity-50 group-hover:scale-150 transition-transform duration-500`}></div>
          
          <!-- 图标 -->
          <div class="text-3xl mb-3 relative z-10">{icon}</div>
          
          <!-- 数值 -->
          <div class:list={['stat-value text-3xl font-bold mb-1 relative z-10', colors.text]}>
            <span class="counter" data-target={stat.value}>0</span>
            {stat.suffix && <span class="text-lg ml-1">{stat.suffix}</span>}
          </div>
          
          <!-- 标签 -->
          <div class="text-sm text-gray-600 dark:text-gray-400 relative z-10">
            {stat.label}
          </div>
          
          <!-- 进度条 -->
          <div class="mt-3 h-1 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden relative z-10">
            <div 
              class:list={['progress-bar h-full rounded-full transition-all duration-1000 ease-out', colors.text.replace('text-', 'bg-')]}
              style="width: 0%"
              data-width={`${Math.min(100, (stat.value / Math.max(...stats.map(s => s.value))) * 100)}%`}
            ></div>
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  function initStatsChart() {
    const containers = document.querySelectorAll('.stats-chart-container');
    
    containers.forEach(container => {
      const isAnimated = container.getAttribute('data-animated') === 'true';
      const counters = container.querySelectorAll('.counter');
      const progressBars = container.querySelectorAll('.progress-bar') as NodeListOf<HTMLElement>;
      
      if (!isAnimated) {
        // 不动画，直接显示
        counters.forEach(counter => {
          counter.textContent = counter.getAttribute('data-target') || '0';
        });
        progressBars.forEach(bar => {
          bar.style.width = bar.getAttribute('data-width') || '0%';
        });
        return;
      }
      
      // 使用 Intersection Observer 触发动画
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateStats();
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      
      observer.observe(container);
      
      function animateStats() {
        // 数字动画
        counters.forEach(counter => {
          const target = parseInt(counter.getAttribute('data-target') || '0');
          const duration = 2000;
          const startTime = performance.now();
          
          function updateCounter(currentTime: number) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            
            // 缓动函数
            const easeOut = 1 - Math.pow(1 - progress, 3);
            const currentValue = Math.round(target * easeOut);
            
            counter.textContent = currentValue.toLocaleString();
            
            if (progress < 1) {
              requestAnimationFrame(updateCounter);
            }
          }
          
          requestAnimationFrame(updateCounter);
        });
        
        // 进度条动画
        setTimeout(() => {
          progressBars.forEach(bar => {
            bar.style.width = bar.getAttribute('data-width') || '0%';
          });
        }, 300);
      }
    });
  }
  
  document.addEventListener('DOMContentLoaded', initStatsChart);
  document.addEventListener('swup:contentReplaced', initStatsChart);
</script>

<style>
  .stat-card {
    animation: fade-in-up 0.5s ease-out forwards;
    opacity: 0;
  }
  
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

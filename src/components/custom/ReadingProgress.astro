---
/**
 * 阅读进度组件
 * 显示预计阅读时间和章节进度跳转
 * 
 * 使用方法:
 * <ReadingProgress wordCount={1500} headings={[{depth, slug, text}]} />
 */

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  wordCount: number;
  headings?: Heading[];
  wordsPerMinute?: number;
  showChapterNav?: boolean;
  class?: string;
}

const { 
  wordCount, 
  headings = [],
  wordsPerMinute = 300,
  showChapterNav = true,
  class: className 
} = Astro.props;

const readingTime = Math.max(1, Math.ceil(wordCount / wordsPerMinute));
const h2Headings = headings.filter(h => h.depth === 2);
---

<div 
  class:list={['reading-progress-container', className]}
  data-headings={JSON.stringify(h2Headings)}
>
  <!-- 顶部进度条 -->
  <div class="reading-progress-bar fixed top-0 left-0 w-full h-1 z-50">
    <div class="progress-fill h-full bg-gradient-to-r from-primary-500 via-purple-500 to-pink-500 transition-all duration-150" style="width: 0%"></div>
  </div>

  <!-- 阅读信息卡片 -->
  <div class="reading-info bg-gradient-to-r from-primary-500/10 to-purple-500/10 dark:from-primary-500/20 dark:to-purple-500/20 rounded-xl p-4 mb-6 border border-primary-500/20">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <!-- 阅读时间 -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-primary-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <div class="text-sm text-gray-500 dark:text-gray-400">预计阅读时间</div>
          <div class="font-bold text-lg text-gray-900 dark:text-white">
            {readingTime} 分钟
          </div>
        </div>
      </div>
      
      <!-- 字数统计 -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <div class="text-sm text-gray-500 dark:text-gray-400">全文字数</div>
          <div class="font-bold text-lg text-gray-900 dark:text-white">
            {wordCount.toLocaleString()} 字
          </div>
        </div>
      </div>
      
      <!-- 阅读进度 -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-pink-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <div>
          <div class="text-sm text-gray-500 dark:text-gray-400">阅读进度</div>
          <div class="font-bold text-lg text-gray-900 dark:text-white">
            <span class="progress-percent">0</span>%
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 章节导航 -->
  {showChapterNav && h2Headings.length > 0 && (
    <div class="chapter-nav mb-6">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        <span class="font-medium text-gray-700 dark:text-gray-300">章节导航</span>
      </div>
      <div class="flex flex-wrap gap-2">
        {h2Headings.map((heading, index) => (
          <a 
            href={`#${heading.slug}`}
            class="chapter-link px-3 py-1.5 text-sm rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-primary-500 hover:text-white transition-all duration-200"
            data-slug={heading.slug}
          >
            <span class="chapter-num opacity-50 mr-1">{index + 1}.</span>
            {heading.text}
          </a>
        ))}
      </div>
    </div>
  )}
</div>

<!-- 浮动章节指示器 -->
{showChapterNav && h2Headings.length > 0 && (
  <div class="chapter-indicator fixed right-4 top-1/2 -translate-y-1/2 z-40 hidden lg:block">
    <div class="flex flex-col gap-2">
      {h2Headings.map((heading, index) => (
        <a 
          href={`#${heading.slug}`}
          class="indicator-dot group relative w-3 h-3 rounded-full bg-gray-300 dark:bg-gray-600 hover:bg-primary-500 transition-all"
          data-slug={heading.slug}
          title={heading.text}
        >
          <span class="absolute right-6 top-1/2 -translate-y-1/2 px-2 py-1 text-xs bg-gray-900 text-white rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
            {heading.text}
          </span>
        </a>
      ))}
    </div>
  </div>
)}

<script>
  function initReadingProgress() {
    const container = document.querySelector('.reading-progress-container');
    if (!container) return;
    
    const progressFill = document.querySelector('.progress-fill') as HTMLElement;
    const progressPercent = document.querySelector('.progress-percent');
    const chapterLinks = document.querySelectorAll('.chapter-link, .indicator-dot');
    
    // 获取文章内容区域
    const article = document.querySelector('article') || document.body;
    const headings = JSON.parse(container.getAttribute('data-headings') || '[]');
    
    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = article.scrollHeight - window.innerHeight;
      const progress = Math.min(100, Math.max(0, (scrollTop / docHeight) * 100));
      
      if (progressFill) {
        progressFill.style.width = `${progress}%`;
      }
      if (progressPercent) {
        progressPercent.textContent = Math.round(progress).toString();
      }
      
      // 更新当前章节高亮
      let currentSlug = '';
      for (const heading of headings) {
        const element = document.getElementById(heading.slug);
        if (element && element.getBoundingClientRect().top <= 100) {
          currentSlug = heading.slug;
        }
      }
      
      chapterLinks.forEach(link => {
        const isActive = link.getAttribute('data-slug') === currentSlug;
        link.classList.toggle('bg-primary-500', isActive);
        link.classList.toggle('text-white', isActive);
      });
    }
    
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }
  
  // 页面加载和 Swup 导航后初始化
  document.addEventListener('DOMContentLoaded', initReadingProgress);
  document.addEventListener('swup:contentReplaced', initReadingProgress);
</script>

<style>
  .chapter-link.bg-primary-500 {
    box-shadow: 0 4px 14px -3px rgba(99, 102, 241, 0.4);
  }
  
  .indicator-dot.bg-primary-500 {
    transform: scale(1.3);
  }
</style>
